{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/about",
      "regex": "^/about(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/about(?:/)?$"
    },
    {
      "page": "/adaptive-ux-sprint",
      "regex": "^/adaptive\\-ux\\-sprint(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/adaptive\\-ux\\-sprint(?:/)?$"
    },
    {
      "page": "/brand",
      "regex": "^/brand(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/brand(?:/)?$"
    },
    {
      "page": "/case-studies",
      "regex": "^/case\\-studies(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/case\\-studies(?:/)?$"
    },
    {
      "page": "/case-studies/activation",
      "regex": "^/case\\-studies/activation(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/case\\-studies/activation(?:/)?$"
    },
    {
      "page": "/case-studies/ai-tool",
      "regex": "^/case\\-studies/ai\\-tool(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/case\\-studies/ai\\-tool(?:/)?$"
    },
    {
      "page": "/case-studies/retention",
      "regex": "^/case\\-studies/retention(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/case\\-studies/retention(?:/)?$"
    },
    {
      "page": "/case-studies/system",
      "regex": "^/case\\-studies/system(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/case\\-studies/system(?:/)?$"
    },
    {
      "page": "/case-studies/travel",
      "regex": "^/case\\-studies/travel(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/case\\-studies/travel(?:/)?$"
    },
    {
      "page": "/contact",
      "regex": "^/contact(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/contact(?:/)?$"
    },
    {
      "page": "/how-it-works",
      "regex": "^/how\\-it\\-works(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/how\\-it\\-works(?:/)?$"
    },
    {
      "page": "/services",
      "regex": "^/services(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/services(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "rsc",
    "varyHeader": "rsc, next-router-state-tree, next-router-prefetch, next-router-segment-prefetch",
    "prefetchHeader": "next-router-prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSuffix": ".prefetch.rsc",
    "prefetchSegmentHeader": "next-router-segment-prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments"
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  }
}